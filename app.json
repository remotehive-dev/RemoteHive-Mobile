{
  "expo": {
    "name": "RemoteHive",
    "slug": "remotehive-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "remotehive",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#007AFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.remotehive.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "package": "com.remotehive.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "*.remotehive.in" }, { "scheme": "https", "host": "remotehive.in" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": { "favicon": "./assets/favicon.png" },
    "extra": {
      "clerkPublishableKey": "pk_test_bG92ZWQtbGlnZXItNjcuY2xlcmsuYWNjb3VudHMuZGV2JA",
      "supabaseUrl": "https://kvpgsbnwzsqflkeihnyo.supabase.co",
